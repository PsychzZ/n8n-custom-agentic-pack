{
  "name": "n8n-nodes-agentic-pack",
  "version": "0.1.0",
  "description": "Stateful agent architecture via specialized custom nodes in n8n — Bachelor Thesis Artifact",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "lint": "eslint nodes/**/*.ts credentials/**/*.ts --ext .ts",
    "lint:fix": "eslint nodes/**/*.ts credentials/**/*.ts --ext .ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "custom-node",
    "agent",
    "react",
    "vector-store",
    "chromadb",
    "llm",
    "bachelor-thesis"
  ],
  "license": "MIT",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ChromaDbApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AgentStateNode/AgentStateNode.node.js",
      "dist/nodes/VectorStoreNode/VectorStoreNode.node.js",
      "dist/nodes/ReActLoopNode/ReActLoopNode.node.js"
    ]
  },
  "dependencies": {
    "chromadb": "^1.8.1",
    "openai": "^4.47.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.17.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
